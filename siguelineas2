#include <Servo.h>
Servo motor4;
Servo motor8;
void setup() {
 motor4.attach(4);
 motor8.attach(8);

 //pines de entrada
 pinMode(2, INPUT);
 pinMode(3, INPUT);

Serial.begin(9600);
Serial.println("--- Sistema Iniciado ---");
}
void loop() {
  int valorDerecha;
  int valorIzquierda;

    //lectura de sensores 
  valorDerecha = digitalRead(3);
  valorIzquierda = digitalRead(2);
  if(valorDerecha==1 && valorIzquierda==1){
    atras();
  }else if(valorDerecha==1 && valorIzquierda==0){
    izquierda();
  }else if(valorDerecha==0 && valorIzquierda==1){
    izquierda();
  }else{
    delante();
  }
  
}
void delante() {
  motor4.write(-180);
  motor8.write(90);
  Serial.println("Yendo hacia adelante");
}
void atras() {
  motor4.write(0);
  motor8.write(-180);
  Serial.println("Yendo hacia atras");
}
void izquierda() {
  motor4.write(-180);
  motor8.write(-90);
  Serial.println("Yendo hacia la Izquierda");
}
void derecha() {
motor4.write(180);
  motor8.write(90);
  Serial.println("Yendo hacia la Derecha");
}